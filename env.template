# AORGO Environment Configuration
# Copy this file to .env.local and fill in real values.

# ── Firebase (client SDK) ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (only if Firebase Analytics is enabled):
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (server SDK) ─────────────────────────────────────────
# Encode your service-account.json file to a single-line base64 string and
# paste it below. Generate with:
#   node -e "console.log(require('fs').readFileSync('service-account.json','utf8').replace(/\s+/g,'').replace(/'/g,\"\\\\'\"))" | base64 -w0
#   # or PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes('service-account.json'))
# The committed service-account.json has been removed from the repo for
# security; keep it OUT of git. Add it to .gitignore (already done).
FIREBASE_ADMIN_CREDENTIALS_BASE64=

# ── Cloudinary (browser uploads; replaces Firebase Storage) ─────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Optional server-side signed-upload helpers (only needed if you later
# switch from the unsigned preset to signed uploads):
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Admin bootstrap (for the make-admin script) ─────────────────────────
ADMIN_EMAIL=admin@aorgo.com
ADMIN_PASSWORD=ChangeMe123!

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="AORGO"
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "true" ONLY in local/dev to serve mock catalog data when Firestore is
# empty or unreachable. Leave unset/false in production so real empty states show.
NEXT_PUBLIC_USE_MOCKS=false
NODE_ENV=development