rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userPath() { return /databases/$(database)/documents/users/$(uid()); }
    function isNotSuspended() {
      // NOTE: `.get('suspended', false)` — NOT `.data.suspended`. New user docs
      // are created without a `suspended` field, and directly reading a missing
      // document field raises an evaluation error in Firestore rules, which then
      // denies the whole request. That silently broke every authenticated write
      // gated by this helper (cart/wishlist sync, saving a checkout address) and
      // every admin collection read (which needs isAdmin() → isNotSuspended()).
      return isSignedIn()
        && (!exists(userPath()) || get(userPath()).data.get('suspended', false) != true);
    }
    function role() {
      return request.auth.token.role;
    }
    function isCustomer() { return isNotSuspended() && (role() == 'customer' || role() == null); }
    function isSeller()   { return isNotSuspended() && role() == 'seller'; }
    function isAdmin()    { return isNotSuspended() && role() == 'admin'; }
    function hasApprovedStore(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId))
        && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == uid()
        && get(/databases/$(database)/documents/stores/$(storeId)).data.status == 'approved';
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read:   if isAdmin() || (isSignedIn() && uid() == userId);
      allow create: if isSignedIn()
                    && uid() == userId
                    && request.resource.data.role in ['customer', 'seller'];
      allow update: if (isNotSuspended()
                       && uid() == userId
                       && !('role' in request.resource.data.diff(resource.data).affectedKeys())
                       && !('suspended' in request.resource.data.diff(resource.data).affectedKeys()))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== STORES =====
    match /stores/{storeId} {
      // Public can browse approved stores; owners/admins can see their own in any state.
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isSeller() && resource.data.ownerUid == uid());
      allow create: if isSeller()
                    && request.resource.data.ownerUid == uid()
                    && request.resource.data.status == 'pending';
      allow update: if (isSeller() && resource.data.ownerUid == uid()
                       && !('status' in request.resource.data.diff(resource.data).affectedKeys())
                       && !('commissionRate' in request.resource.data.diff(resource.data).affectedKeys()))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== PRODUCTS =====
    match /products/{productId} {
      allow read: if resource.data.status == 'approved'
                  || isAdmin()
                  || (isSeller() && resource.data.sellerUid == uid());
      allow create: if isSeller()
                    && request.resource.data.sellerUid == uid()
                    && request.resource.data.status in ['draft', 'pending']
                    && hasApprovedStore(request.resource.data.storeId);
      allow update: if (isSeller() && resource.data.sellerUid == uid()
                       && hasApprovedStore(resource.data.storeId)
                       && !('status' in request.resource.data.diff(resource.data).affectedKeys()))
                    || isAdmin();
      allow delete: if isAdmin()
                    || (isSeller() && resource.data.sellerUid == uid() && hasApprovedStore(resource.data.storeId));
    }

    // ===== ORDERS =====
    match /orders/{orderId} {
      allow read: if isAdmin()
                  || (isCustomer() && resource.data.customerUid == uid())
                  || (isSeller()   && resource.data.storeOwnerUid == uid());
      allow create: if false;
      // Sellers may only fulfil their own orders and may only touch fulfilment
      // fields — never financial fields (totals, items, payment, ownership).
      allow update: if isAdmin()
                    || (isSeller() && resource.data.storeOwnerUid == uid()
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'shipping', 'statusHistory', 'updatedAt']));
      allow delete: if false;
    }

    // ===== WISHLISTS =====
    match /wishlists/{userId} {
      allow read, write: if isNotSuspended() && uid() == userId;
    }

    // ===== CARTS =====
    match /carts/{userId} {
      allow read, write: if isNotSuspended() && uid() == userId;
    }

    // ===== REVIEWS =====
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ===== CATEGORIES, BANNERS, SETTINGS =====
    match /categories/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /banners/{id} {
      allow read: if resource.data.get('active', false) == true || isAdmin();
      allow write: if isAdmin();
    }
    match /settings/{key} {
      allow read: if key in ['public', 'storefront', 'shipping', 'promos'];
      allow write: if isAdmin();
    }

    // ===== NOTIFICATIONS =====
    match /notifications/{id} {
      allow read: if isNotSuspended() && resource.data.recipientUid == uid();
      // Recipients may only flip the 'read' flag, not rewrite the notification.
      allow update: if isNotSuspended() && resource.data.recipientUid == uid()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== AUDIT LOGS =====
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}